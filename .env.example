# Supabase — Session Pooler (port 5432) — used by Prisma CLI (prisma db push, prisma studio)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase — Transaction Pooler (port 6543) — used by the running Next.js app
DATABASE_URL_UNPOOLED="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Admin dashboard password
ADMIN_PASSWORD="choose-a-strong-password"

# Google Places API key (restrict to Maps JavaScript API, California/US only)
NEXT_PUBLIC_GOOGLE_PLACES_KEY="your-google-places-api-key"

# Contact phone number shown to students (US format)
NEXT_PUBLIC_CONTACT_NUMBER="+12135550000"
